# Supabase — get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Clerk Authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenRouter — for plain English prompt mode (Mode 2)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: override the default model (google/gemini-2.0-flash-001)
# OPENROUTER_MODEL=google/gemini-2.0-flash-001

# Polar — billing & subscriptions
# Get these from https://polar.sh/settings
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=whsec_...
# Product IDs from your Polar product dashboard
POLAR_PRO_PRODUCT_ID=
POLAR_SCALE_PRODUCT_ID=
# Set to "true" for sandbox testing, remove or set to "false" for production
# POLAR_SANDBOX=true

# x402 — experimental direct crypto settlement.
# Keep disabled when Polar should remain the Merchant of Record checkout path.
ENABLE_DIRECT_X402=false
# X402_PAY_TO is the wallet address that receives direct paid API-call settlement.
# Do not set this in production unless direct crypto sales tax/compliance handling is approved.
X402_PAY_TO=
X402_NETWORK=base
X402_FACILITATOR_URL=
X402_PRICE_PER_GENERATE_REQUEST_USD=0.001
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# Brevo — transactional email
# Get from https://app.brevo.com/settings/keys/smtp
BREVO_API_KEY=
BREVO_SMTP_LOGIN=
BREVO_SMTP_KEY=
BREVO_FROM_EMAIL=notifications@mockhero.dev
