{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "declaration": true,
    "paths": {
      "@engine": ["../../src/lib/engine/index"],
      "@engine/*": ["../../src/lib/engine/*"]
    }
  },
  "include": ["src/**/*.ts"]
}
